# Copy this file to .env and fill in your actual values

# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# n8n Webhook Configuration
# Temporary test URL - replace with your n8n webhook URL
N8N_WEBHOOK_URL=http://n8n:5678/webhook/[your_webhook_id_here]

# Optional: Channel ID to monitor (leave empty to monitor all channels)
DISCORD_CHANNEL_ID=

# Optional: Guild ID to restrict bot to specific server
DISCORD_GUILD_ID=